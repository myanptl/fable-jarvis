    "cli",
    "claude",
    "anthropic",
    "agent",
    "daily-briefing",
    "productivity"
  ],
  "author": "Myan Patel (https://github.com/myanptl)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myanptl/fable-jarvis.git"
  },
  "homepage": "https://github.com/myanptl/fable-jarvis#readme",
  "bugs": {
    "url": "https://github.com/myanptl/fable-jarvis/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
