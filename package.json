{
  "name": "fable-jarvis",
  "version": "1.0.0",
  "description": "Your own JARVIS in the terminal — a Claude-powered personal assistant with memory, daily briefings, and a personality.",
  "type": "module",
  "bin": {
    "jarvis": "dist/cli.js"
  },
  "files": [
